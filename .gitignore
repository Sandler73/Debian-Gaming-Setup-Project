# ═══════════════════════════════════════════════════════════════════════════════
# Debian Gaming Setup Script — .gitignore
# ═══════════════════════════════════════════════════════════════════════════════
#
# Comprehensive exclusion rules for Python projects on Linux with coverage
# for all common development environments, testing frameworks, packaging
# tools, and operating system artifacts.
#
# Sections:
#   1. Python runtime artifacts
#   2. Testing & coverage
#   3. Virtual environments
#   4. Distribution & packaging
#   5. Documentation build
#   6. IDE & editor files
#   7. Operating system files
#   8. Security & secrets
#   9. Project-specific exclusions
#
# VERSION: 3.4.0
# ═══════════════════════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────────────────────────
# 1. Python Runtime Artifacts
# ─────────────────────────────────────────────────────────────────────────────

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Cython debug symbols
cython_debug/

# Type checker caches
.mypy_cache/
.pytype/
.pyre/

# Rope project settings (refactoring tool)
.ropeproject/


# ─────────────────────────────────────────────────────────────────────────────
# 2. Testing & Coverage
# ─────────────────────────────────────────────────────────────────────────────

# pytest
.pytest_cache/
pytest_cache/
.pytest_tmp/

# Coverage.py
.coverage
.coverage.*
htmlcov/
coverage.xml
coverage.json
*.cover
*.py,cover

# tox
.tox/

# nox
.nox/

# Hypothesis (property-based testing)
.hypothesis/

# Test output and reports
test-results/
test-reports/
junit*.xml
nosetests.xml

# Bandit (security scanner)
bandit-report.*
.bandit/


# ─────────────────────────────────────────────────────────────────────────────
# 3. Virtual Environments
# ─────────────────────────────────────────────────────────────────────────────

# Standard virtual environment directories
.env/
.venv/
env/
venv/
ENV/
VENV/

# Virtualenv
.virtualenv/

# Conda
.conda/
*.conda
environment.lock

# Poetry
poetry.lock

# Pipenv
Pipfile.lock

# PDM
.pdm.toml
.pdm-python
__pypackages__/

# pip
pip-log.txt
pip-delete-this-directory.txt


# ─────────────────────────────────────────────────────────────────────────────
# 4. Distribution & Packaging
# ─────────────────────────────────────────────────────────────────────────────

# Build artifacts
build/
dist/
*.egg-info/
*.egg
eggs/
*.whl

# Source distribution
sdist/
MANIFEST

# Installer logs
pip-wheel-metadata/
*.dist-info/

# PyInstaller
*.manifest
*.spec

# Debian packaging
*.deb
*.changes
*.buildinfo
debian/.debhelper/
debian/debhelper-build-stamp
debian/files
debian/*.substvars
debian/tmp/

# Archive artifacts (generated by make package)
debian-gaming-setup-v*.zip
debian-gaming-setup-v*.tar.gz


# ─────────────────────────────────────────────────────────────────────────────
# 5. Documentation Build
# ─────────────────────────────────────────────────────────────────────────────

# Sphinx documentation
docs/_build/
docs/_static/
docs/_templates/

# MkDocs
site/

# Jupyter notebooks
.ipynb_checkpoints/
*.ipynb_checkpoints

# Rendered documentation artifacts
*.pdf
*.html
!docs/**/*.html


# ─────────────────────────────────────────────────────────────────────────────
# 6. IDE & Editor Files
# ─────────────────────────────────────────────────────────────────────────────

# Visual Studio Code
.vscode/
*.code-workspace

# JetBrains (PyCharm, IntelliJ, etc.)
.idea/
*.iml
*.iws
*.ipr
out/

# Sublime Text
*.sublime-workspace
*.sublime-project

# Vim / Neovim
*.swp
*.swo
*.swn
*~
.netrwhist
tags
.tags
Session.vim
.vim/

# Emacs
*~
\#*\#
.#*
*.elc
auto-save-list/
tramp

# Kate
.kate-swp

# Geany
*.geany

# Eclipse
.project
.pydevproject
.settings/
.classpath

# Spyder
.spyderproject
.spyproject

# TextMate
*.tmproj
*.tmproject
tmtags

# Atom
.atom/

# Fleet (JetBrains)
.fleet/

# Zed
.zed/


# ─────────────────────────────────────────────────────────────────────────────
# 7. Operating System Files
# ─────────────────────────────────────────────────────────────────────────────

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# macOS (in case of cross-platform development)
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon?

# Windows (in case of cross-platform development)
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Thumbnail caches
*.stackdump


# ─────────────────────────────────────────────────────────────────────────────
# 8. Security & Secrets
# ─────────────────────────────────────────────────────────────────────────────

# Environment files with secrets
.env
.env.local
.env.*.local
*.env

# Private keys
*.pem
*.key
*.p12
*.pfx
id_rsa
id_ed25519

# Credentials
credentials.json
token.json
secrets.yaml
secrets.yml
*.secret

# AWS
.aws/

# GCP
.gcloud/

# SSH
.ssh/


# ─────────────────────────────────────────────────────────────────────────────
# 9. Project-Specific Exclusions
# ─────────────────────────────────────────────────────────────────────────────

# Temporary lint extraction files
/tmp/lint_*.sh
/tmp/lg_*.sh

# Gaming setup log and state files (generated at runtime, not tracked)
gaming_setup_logs/
gaming_setup_backups/
installation_state.json
rollback_manifest.json
rollback_manifest.json.*

# Generated performance launcher (created by the script at runtime)
launch-game.sh

# Backup files created during self-update
debian_gaming_setup.py.*.backup
debian_gaming_setup.py.new

# MangoHud and vkBasalt configs (generated at runtime)
MangoHud.conf
vkBasalt.conf

# Pre-commit hook cache
.pre-commit-cache/
